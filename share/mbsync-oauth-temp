IMAPStore $fulladdr-remote
Host $imap
Port $iport
User $login
PassCmd "python3 $oauth2script $oauth2tokenfile"
AuthMechs XOAUTH2
TLSType $imapssl
CertificateFile $sslcert

MaildirStore $fulladdr-local
Subfolders Verbatim
Path $maildir/$fulladdr/
Inbox $maildir/$fulladdr/INBOX

Channel $fulladdr
Expunge Both
$master :$fulladdr-remote:
$slave :$fulladdr-local:
Patterns * !"[Gmail]/All Mail" !"*fts-flatcurve*" !"*virtual*"
Create Both
SyncState *
MaxMessages $maxmes
ExpireUnread no
# End profile
